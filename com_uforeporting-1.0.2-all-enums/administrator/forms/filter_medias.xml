<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" description="COM_UFOREPORTING_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <field name="state"
               type="status"
               label="COM_UFOREPORTING_FILTER_STATE"
               description="COM_UFOREPORTING_FILTER_STATE_DESC"
               onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        

    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_UFOREPORTING_LIST_FULL_ORDERING"
               description="COM_UFOREPORTING_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">COM_UFOREPORTING_ID_ASC</option><option value="a.id DESC">COM_UFOREPORTING_ID_DESC</option><option value="a.sighting_id ASC">COM_UFOREPORTING_SIGHTING_ID_ASC</option><option value="a.sighting_id DESC">COM_UFOREPORTING_SIGHTING_ID_DESC</option><option value="a.kind ASC">COM_UFOREPORTING_KIND_ASC</option><option value="a.kind DESC">COM_UFOREPORTING_KIND_DESC</option><option value="a.uri ASC">COM_UFOREPORTING_URI_ASC</option><option value="a.uri DESC">COM_UFOREPORTING_URI_DESC</option><option value="a.mime ASC">COM_UFOREPORTING_MIME_ASC</option><option value="a.mime DESC">COM_UFOREPORTING_MIME_DESC</option><option value="a.captured_at ASC">COM_UFOREPORTING_CAPTURED_AT_ASC</option><option value="a.captured_at DESC">COM_UFOREPORTING_CAPTURED_AT_DESC</option><option value="a.meta ASC">COM_UFOREPORTING_META_ASC</option><option value="a.meta DESC">COM_UFOREPORTING_META_DESC</option><option value="a.created_at ASC">COM_UFOREPORTING_CREATED_AT_ASC</option><option value="a.created_at DESC">COM_UFOREPORTING_CREATED_AT_DESC</option><option value="a.ordering ASC">COM_UFOREPORTING_ORDERING_ASC</option><option value="a.ordering DESC">COM_UFOREPORTING_ORDERING_DESC</option><option value="a.state ASC">COM_UFOREPORTING_STATE_ASC</option><option value="a.state DESC">COM_UFOREPORTING_STATE_DESC</option><option value="a.created_by ASC">COM_UFOREPORTING_CREATED_BY_ASC</option><option value="a.created_by DESC">COM_UFOREPORTING_CREATED_BY_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_UFOREPORTING_LIST_LIMIT"
               description="COM_UFOREPORTING_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>