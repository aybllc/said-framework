<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Uforresporting\Component\Uforeporting\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="sighting_id" type="text" label="COM_UFOREPORTING_FORM_LBL_WITNESSE_SIGHTING_ID" description="COM_UFOREPORTING_FORM_DESC_WITNESSE_SIGHTING_ID" hint="COM_UFOREPORTING_FORM_LBL_WITNESSE_SIGHTING_ID"/>
    <field name="label" type="text" label="COM_UFOREPORTING_FORM_LBL_WITNESSE_LABEL" description="COM_UFOREPORTING_FORM_DESC_WITNESSE_LABEL" hint="COM_UFOREPORTING_FORM_LBL_WITNESSE_LABEL"/>
    <field name="notes" type="text" label="COM_UFOREPORTING_FORM_LBL_WITNESSE_NOTES" description="COM_UFOREPORTING_FORM_DESC_WITNESSE_NOTES" hint="COM_UFOREPORTING_FORM_LBL_WITNESSE_NOTES"/>
    <field name="created_at" default="CURRENT_TIMESTAMP" type="calendar" class="inputbox" format="%Y-%m-%d %H:%M:%S" showtime="true" translateformat="true" label="COM_UFOREPORTING_FORM_LBL_WITNESSE_CREATED_AT" description="COM_UFOREPORTING_FORM_DESC_WITNESSE_CREATED_AT" hint="COM_UFOREPORTING_FORM_LBL_WITNESSE_CREATED_AT"/>
    <field name="ordering"/>
    <field name="state" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1" default="0">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" default="1000-01-01 00:00:00" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hint="COM_UFOREPORTING_FORM_LBL_WITNESSE_CREATED_BY"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
  <fieldset name="accesscontrol">
    <field name="asset_id" type="hidden" filter="unset"/>
    <field name="rules" type="rules" label="JFIELD_RULES_LABEL" translate_label="false" filter="rules" validate="rules" class="inputbox" component="com_uforeporting" section="witnesse"/>
  </fieldset>
</form>
