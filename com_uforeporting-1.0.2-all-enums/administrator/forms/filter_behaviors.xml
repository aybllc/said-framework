<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" description="COM_UFOREPORTING_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <field name="state"
               type="status"
               label="COM_UFOREPORTING_FILTER_STATE"
               description="COM_UFOREPORTING_FILTER_STATE_DESC"
               onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        

    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_UFOREPORTING_LIST_FULL_ORDERING"
               description="COM_UFOREPORTING_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.behavior_code ASC">COM_UFOREPORTING_BEHAVIOR_CODE_ASC</option><option value="a.behavior_code DESC">COM_UFOREPORTING_BEHAVIOR_CODE_DESC</option><option value="a.behavior_name ASC">COM_UFOREPORTING_BEHAVIOR_NAME_ASC</option><option value="a.behavior_name DESC">COM_UFOREPORTING_BEHAVIOR_NAME_DESC</option><option value="a.behavior_description ASC">COM_UFOREPORTING_BEHAVIOR_DESCRIPTION_ASC</option><option value="a.behavior_description DESC">COM_UFOREPORTING_BEHAVIOR_DESCRIPTION_DESC</option><option value="a.id ASC">COM_UFOREPORTING_ID_ASC</option><option value="a.id DESC">COM_UFOREPORTING_ID_DESC</option><option value="a.ordering ASC">COM_UFOREPORTING_ORDERING_ASC</option><option value="a.ordering DESC">COM_UFOREPORTING_ORDERING_DESC</option><option value="a.state ASC">COM_UFOREPORTING_STATE_ASC</option><option value="a.state DESC">COM_UFOREPORTING_STATE_DESC</option><option value="a.created_by ASC">COM_UFOREPORTING_CREATED_BY_ASC</option><option value="a.created_by DESC">COM_UFOREPORTING_CREATED_BY_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_UFOREPORTING_LIST_LIMIT"
               description="COM_UFOREPORTING_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>