<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Uforresporting\Component\Uforeporting\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="sighting_id" type="text" label="COM_UFOREPORTING_FORM_LBL_MEDIA_SIGHTING_ID" description="COM_UFOREPORTING_FORM_DESC_MEDIA_SIGHTING_ID" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_SIGHTING_ID"/>
    <field name="kind" type="text" label="COM_UFOREPORTING_FORM_LBL_MEDIA_KIND" description="COM_UFOREPORTING_FORM_DESC_MEDIA_KIND" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_KIND"/>
    <field name="uri" type="text" label="COM_UFOREPORTING_FORM_LBL_MEDIA_URI" description="COM_UFOREPORTING_FORM_DESC_MEDIA_URI" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_URI"/>
    <field name="mime" type="text" label="COM_UFOREPORTING_FORM_LBL_MEDIA_MIME" description="COM_UFOREPORTING_FORM_DESC_MEDIA_MIME" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_MIME"/>
    <field name="captured_at" type="calendar" class="inputbox" format="%Y-%m-%d %H:%M:%S" showtime="true" translateformat="true" label="COM_UFOREPORTING_FORM_LBL_MEDIA_CAPTURED_AT" description="COM_UFOREPORTING_FORM_DESC_MEDIA_CAPTURED_AT" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_CAPTURED_AT"/>
    <field name="meta" label="COM_UFOREPORTING_FORM_LBL_MEDIA_META" description="COM_UFOREPORTING_FORM_DESC_MEDIA_META" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_META"/>
    <field name="created_at" default="CURRENT_TIMESTAMP" type="calendar" class="inputbox" format="%Y-%m-%d %H:%M:%S" showtime="true" translateformat="true" label="COM_UFOREPORTING_FORM_LBL_MEDIA_CREATED_AT" description="COM_UFOREPORTING_FORM_DESC_MEDIA_CREATED_AT" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_CREATED_AT"/>
    <field name="ordering"/>
    <field name="state" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1" default="0">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" default="1000-01-01 00:00:00" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hint="COM_UFOREPORTING_FORM_LBL_MEDIA_CREATED_BY"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
  <fieldset name="accesscontrol">
    <field name="asset_id" type="hidden" filter="unset"/>
    <field name="rules" type="rules" label="JFIELD_RULES_LABEL" translate_label="false" filter="rules" validate="rules" class="inputbox" component="com_uforeporting" section="media"/>
  </fieldset>
</form>
