<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Uforresporting\Component\Uforeporting\Site\Field">
  <fieldset>
    <field name="code" id="code" type="list" class="inputbox" required="true" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_CODE" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_CODE" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_CODE">
      <option value="F">F</option>
      <option value="M">M</option>
      <option value="C">C</option>
      <option value="E">E</option>
      <option value="S">S</option>
      <option value="A">A</option>
      <option value="O">O</option>
      <option value="H">H</option>
      <option value="D">D</option>
      <option value="I">I</option>
      <option value="G">G</option>
    </field>
    <field name="name" type="text" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_NAME" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_NAME" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_NAME"/>
    <field name="description" type="text" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_DESCRIPTION" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_DESCRIPTION" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_DESCRIPTION"/>
    <field name="minus_range" type="text" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_MINUS_RANGE" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_MINUS_RANGE" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_MINUS_RANGE"/>
    <field name="equal_range" type="text" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_EQUAL_RANGE" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_EQUAL_RANGE" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_EQUAL_RANGE"/>
    <field name="plus_range" type="text" label="COM_UFOREPORTING_FORM_LBL_DOMAIN_PLUS_RANGE" description="COM_UFOREPORTING_FORM_DESC_DOMAIN_PLUS_RANGE" hint="COM_UFOREPORTING_FORM_LBL_DOMAIN_PLUS_RANGE"/>
    <field name="state" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1" default="0">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" default="1000-01-01 00:00:00" type="hidden" filter="unset"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
</form>
