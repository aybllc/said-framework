[
  {
    "_comment": "Directory rules first — first-match-wins, so these override extension rules below",
    "pattern": "(^|/)secrets?(/|$)",
    "level": "private"
  },
  {
    "pattern": "(^|/)raw(_|\\-)?data(/|$)",
    "level": "private"
  },
  {
    "pattern": "(^|/)notebooks?(/|$)",
    "level": "restricted"
  },
  {
    "pattern": "(^|/)models?(/|$)",
    "level": "restricted"
  },
  {
    "_comment": "Extension rules after directory rules",
    "pattern": "\\.(fits|fit|hdf5?|parquet|npz|npy|gz|bz2|xz)$",
    "level": "private"
  },
  {
    "pattern": "\\.(py|md|txt|tex|yaml|yml|toml|cfg|ini)$",
    "level": "public"
  },
  {
    "pattern": "\\.(json|ipynb)$",
    "level": "public"
  }
]